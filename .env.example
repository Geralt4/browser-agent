# Copy to .env and fill in. Field names map 1:1 to Config (case-insensitive).

# Model provider: "kimi" (target) or "openai" (generic, OpenAI-compatible smoke test)
PROVIDER=openai

# --- Kimi / Moonshot (PROVIDER=kimi) ---
MOONSHOT_API_KEY=

# --- Generic OpenAI-compatible provider (PROVIDER=openai) ---
# Leave LLM_BASE_URL blank to hit api.openai.com.
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=

# --- Browser / loop ---
HEADLESS=true
MAX_STEPS=25

# --- Vision routing ---
# "dom" = always DOM-only, "auto" = per-task heuristic, "vision" = always use vision
VISION_MODE=auto
# Comma-separated list of vision-capable model names (for Ollama Cloud / custom providers)
# Example: VISION_MODELS=gpt-4o,llama-3.2-vision,qwen2.5-vl
VISION_MODELS=

# --- Safety policy (comma-separated host substrings) ---
ALLOWLIST=
BLOCKLIST=
KILL_SWITCH=false
# LLM-based sensitivity classification fallback (costs an extra API call per action).
# Off by default; enable for production hardening.
SENSITIVITY_LLM=false
