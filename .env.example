# Copy to .env and fill in. Field names map 1:1 to Config (case-insensitive).

# Model provider: "kimi" (default, Moonshot K2.6) or "openai" (generic, OpenAI-compatible smoke test)
PROVIDER=kimi

# --- Kimi / Moonshot (PROVIDER=kimi) ---
MOONSHOT_API_KEY=

# --- Generic OpenAI-compatible provider (PROVIDER=openai) ---
# Leave LLM_BASE_URL blank to hit api.openai.com.
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=

# --- Browser / loop ---
HEADLESS=true
MAX_STEPS=25
# Max chars of DOM content returned by the extract tool (token-window guard).
MAX_EXTRACT_CHARS=8000
# Max concurrent browser-agent tasks; POST /api/task returns 429 when reached.
# Browser sessions are RAM/CPU-heavy — raise only if you have the headroom.
MAX_CONCURRENT_TASKS=3

# --- Vision routing ---
# "vision" = always use vision (default; +9.6pp pass rate vs DOM in 135-task A/B),
# "dom" = always DOM-only, "auto" = per-task keyword heuristic,
# "category" = data-driven per-category routing (see DOM_CATEGORIES below)
VISION_MODE=vision
# Comma-separated list of vision-capable model names (for Ollama Cloud / custom providers)
# Example: VISION_MODELS=gpt-4o,llama-3.2-vision,qwen2.5-vl
VISION_MODELS=
# Categories to route to DOM-only when VISION_MODE=category (comma-separated).
# Leave empty if you don't have repeat-based A/B data yet.
DOM_CATEGORIES=

# --- Safety policy (comma-separated host substrings) ---
ALLOWLIST=
BLOCKLIST=
KILL_SWITCH=false
# Shared secret for UI API endpoints (POST /api/config, GET /api/models).
# When unset, those endpoints return 403. Generate with: openssl rand -hex 32
BROWSER_AGENT_API_TOKEN=
# LLM-based sensitivity classification fallback (costs an extra API call per action).
# Off by default; enable for production hardening.
SENSITIVITY_LLM=false
