{
  "manifest_version": 3,
  "name": "Browser Agent",
  "version": "0.3.0",
  "description": "Open-source browser automation agent. Type a task, watch it execute in the side panel.",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage",
    "sidePanel",
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Open Browser Agent"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
